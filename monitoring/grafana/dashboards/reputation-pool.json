{
  "uid": "reputation-pool-cloud",
  "title": "reputation-pool-cloud · 개요",
  "tags": ["reputation-pool", "d7b"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP 요청율 (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 5xx 비율",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count[5m])), 1)",
          "legendFormat": "5xx 비율"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 지연 p99 / p50 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "JVM 힙 사용 (bytes)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "used"
        },
        {
          "refId": "B",
          "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})",
          "legendFormat": "max"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "DB 커넥션 풀 (HikariCP)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "hikaricp_connections_active",
          "legendFormat": "active"
        },
        {
          "refId": "B",
          "expr": "hikaricp_connections_pending",
          "legendFormat": "pending"
        },
        {
          "refId": "C",
          "expr": "hikaricp_connections",
          "legendFormat": "total"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "도메인 이벤트율 (reputation.*, /s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(reputation_lease_granted_total[5m]))",
          "legendFormat": "lease granted"
        },
        {
          "refId": "B",
          "expr": "sum(rate(reputation_resource_blocklisted_total[5m]))",
          "legendFormat": "blocklisted"
        },
        {
          "refId": "C",
          "expr": "sum(rate(reputation_resource_cooled_total[5m]))",
          "legendFormat": "cooled"
        },
        {
          "refId": "D",
          "expr": "sum(rate(reputation_resource_recovered_total[5m]))",
          "legendFormat": "recovered"
        }
      ]
    }
  ]
}
