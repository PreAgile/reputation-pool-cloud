# Copy to .env for local development: `cp .env.example .env` (`.env` is gitignored — never commit it).
# Docker Compose loads .env automatically. In production these come from a secret store, not a file.

# REQUIRED — the gRPC API key clients send in the x-api-key metadata header. There is deliberately no
# default: a fallback would leave a known key accepting calls on the public API. Use a strong random
# value in production; this local placeholder is only for `docker compose up` on a dev machine.
REPUTATION_POOL_API_KEY=local-dev-key

# Optional — the DB password. compose falls back to a local throwaway for the internal db container
# if unset; set it here (and it is injected into both app and db) to use your own.
# REPUTATION_POOL_DB_PASSWORD=reputation_pool
