# Copy to .env for local development: `cp .env.example .env` (`.env` is gitignored — never commit it).
# Docker Compose loads .env automatically. In production these come from a secret store, not a file.

# REQUIRED — the gRPC API key clients send in the x-api-key metadata header. There is deliberately no
# default: a fallback would leave a known key accepting calls on the public API. Use a strong random
# value in production; this local placeholder is only for `docker compose up` on a dev machine.
REPUTATION_POOL_API_KEY=local-dev-key

# REQUIRED — the Grafana admin password (#14 monitoring stack). No default on purpose: a fallback would
# boot Grafana with a known admin/admin login. Use a strong random value in production; this local
# placeholder is only for `docker compose up` on a dev machine.
GRAFANA_ADMIN_PASSWORD=local-dev-admin

# Optional — the DB password. compose falls back to a local throwaway for the internal db container
# if unset; set it here (and it is injected into both app and db) to use your own.
# REPUTATION_POOL_DB_PASSWORD=reputation_pool

# Optional — REST control-plane admin login (issue #11). Unset leaves the admin console disabled (fail
# closed): POST /api/auth/login cannot mint a token and every /api/** call is rejected, while the gRPC
# data plane still works. Set all three to enable it. The JWT secret MUST be at least 32 bytes (HS256
# needs a 256-bit key); use a strong random value in production, not this local placeholder.
# REPUTATION_POOL_ADMIN_USERNAME=admin
# REPUTATION_POOL_ADMIN_PASSWORD=change-me-local-dev
# REPUTATION_POOL_ADMIN_JWT_SECRET=0123456789abcdef0123456789abcdef
